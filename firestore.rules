rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read/write their own resumes
    match /resumes/{resumeId} {
      // Allow creating a new resume if the data includes the correct userId
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Allow reading, updating, or deleting ONLY if the existing document belongs to the user
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Default: Block access to any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
